{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/notifications/scheduled-sends",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cleanup-idempotency-keys",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/pbv-deferred-reminders",
      "schedule": "0 10 * * *"
    }
  ]
}
